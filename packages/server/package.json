{
  "name": "@todograph/server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./repositories": {
      "types": "./dist/repositories/index.d.ts",
      "import": "./dist/repositories/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/static": "^9.1.1",
    "@todograph/core": "workspace:*",
    "@todograph/shared": "workspace:*",
    "dagre": "^0.8.5",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^7.0.0",
    "proper-lockfile": "^4.1.2",
    "semver": "^7.7.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.52",
    "@types/node": "^22.10.2",
    "@types/proper-lockfile": "^4.1.4",
    "@types/semver": "^7.7.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  }
}
