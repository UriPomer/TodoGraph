{
  "name": "@todograph/app",
  "version": "0.1.0",
  "description": "TodoGraph desktop app (Electron + React + Vite)",
  "author": "TodoGraph",
  "type": "module",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "electron-vite dev",
    "build": "tsc -p tsconfig.node.json && electron-vite build",
    "build:web": "vite build",
    "package": "electron-vite build && electron-builder --win portable",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/static": "^8.0.3",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@todograph/core": "workspace:*",
    "@todograph/server": "workspace:*",
    "@todograph/shared": "workspace:*",
    "@xyflow/react": "^12.3.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.52",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.todograph.app",
    "productName": "TodoGraph",
    "electronVersion": "33.4.11",
    "asar": true,
    "directories": {
      "output": "../../Build",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!**/node_modules/**/{README.md,readme.md,LICENSE,CHANGELOG*,*.d.ts,*.d.ts.map,*.map}",
      "!**/node_modules/**/{test,tests,__tests__,example,examples,docs,doc}/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
