{
  "name": "@todograph/app",
  "version": "0.1.0",
  "description": "TodoGraph web, Electron, and Capacitor app",
  "author": "TodoGraph",
  "type": "module",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "electron-vite dev",
    "build": "tsc -p tsconfig.node.json && electron-vite build",
    "build:web": "vite build",
    "build:mobile": "node scripts/build-mobile.mjs",
    "mobile:android": "cap open android",
    "mobile:ios": "cap open ios",
    "package": "electron-vite build && electron-builder --win portable",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@capacitor/app": "8.1.1",
    "@capacitor/core": "8.4.2",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/keyboard": "8.0.5",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@todograph/core": "workspace:*",
    "@todograph/desktop-host": "workspace:*",
    "@todograph/shared": "workspace:*",
    "@xyflow/react": "^12.3.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@capacitor/android": "8.4.2",
    "@capacitor/cli": "8.4.2",
    "@capacitor/ios": "8.4.2",
    "@playwright/test": "^1.61.1",
    "@types/dagre": "^0.7.52",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/react-test-renderer": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "39.8.5",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.49",
    "react-test-renderer": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "com.todograph.app",
    "productName": "TodoGraph",
    "electronVersion": "39.8.5",
    "asar": true,
    "icon": "build/icon.ico",
    "directories": {
      "output": "../../Build",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json",
      "build/icon.ico",
      "!**/node_modules/**/{README.md,readme.md,LICENSE,CHANGELOG*,*.d.ts,*.d.ts.map,*.map}",
      "!**/node_modules/**/{test,tests,__tests__,example,examples,docs,doc}/**"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": true,
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}.${ext}"
    }
  }
}
